│   ├── globalError.js       # Centralized error handler (dev/prod modes)
│   ├── invoiceController.js # Invoice CRUD + complex creation logic (~33KB)
│   ├── paymentController.js # Payment processing & customer balance updates
│   ├── returnController.js  # Return processing with MongoDB transactions
│   ├── purchaseOrderController.js # PO lifecycle (create, receive, pay, cancel)
│   ├── prescriptionController.js  # Prescription management & dispensing
│   ├── reportController.js  # Dashboard reports & analytics
│   ├── exportController.js  # PDF/Excel export (invoices, statements)
│   ├── productController.js # Product CRUD
│   ├── customerController.js# Customer CRUD + statements
│   ├── stockController.js   # Stock management + adjustments
│   ├── cashController.js    # Cash register operations
│   ├── expenseController.js # Expense management
│   ├── categoryController.js# Category CRUD
│   ├── supplierController.js# Supplier CRUD
│   └── helpers/
│       ├── processInvoiceItems.js  # Invoice item processing logic
│       ├── calculateTotals.js      # Financial calculation helpers
│       ├── transactionHelper.js    # Transaction creation helpers
│       └── updateCustomerInfo.js   # Customer balance update helpers
│
├── routes/                  # 10 route files
